<Window x:Class="BlexAutoClicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Blex Auto"
        Icon="pack://application:,,,/BlexAuto.ico"
        Height="620" Width="780"
        MinHeight="580" MinWidth="680"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="#F0F0F5"
        TextElement.FontFamily="Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="TitleBar_MouseDown">
    <Window.Resources>
        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#7C3AED" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="CardBg" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#151530" Offset="0"/>
            <GradientStop Color="#101025" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="InputBg" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0D0D20" Offset="0"/>
            <GradientStop Color="#0A0A1A" Offset="1"/>
        </LinearGradientBrush>

        <DropShadowEffect x:Key="CardGlow" BlurRadius="20" ShadowDepth="0" Opacity="0.15" Color="#7C3AED"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource CardGlow}"/>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="SliderCustom" TargetType="Slider">
            <Setter Property="Minimum" Value="1"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="RadioOpt" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="Outer" Width="16" Height="16" Stroke="#4B5563" StrokeThickness="2" VerticalAlignment="Center"/>
                            <Ellipse x:Name="Inner" Width="8" Height="8" Fill="{StaticResource AccentGradient}" Opacity="0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Inner" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Inner" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Outer" Property="Stroke" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KeybindButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="#F0F0F5"/>
            <Setter Property="BorderBrush" Value="#2D2D4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}"
                                Cursor="{TemplateBinding Cursor}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#7C3AED"/>
                                <Setter Property="Background" Value="#1A1A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2D2D4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="#0A0A1A" CornerRadius="10" BorderBrush="#2D2D4A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#0F0F25" CornerRadius="10,10,0,0" Padding="16,10" BorderBrush="#1F1F3A" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬡" Foreground="#7C3AED" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="BLEX AUTO" Foreground="{StaticResource AccentGradient}" FontSize="15" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="v1.1" Foreground="#4B5563" FontSize="10" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="MinimizeBtn" Content="─" Background="Transparent" Foreground="#9CA3AF" 
                                BorderThickness="0" Width="36" Height="28" FontSize="14"
                                Cursor="Hand" Click="MinimizeBtn_Click"/>
                        <Button x:Name="CloseBtn" Content="✕" Background="Transparent" Foreground="#9CA3AF" 
                                BorderThickness="0" Width="36" Height="28" FontSize="14"
                                Cursor="Hand" Click="CloseBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12,20,16">
                <StackPanel>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="CLICK RATE" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="CpsSlider" Style="{StaticResource SliderCustom}"
                                        Value="10" ValueChanged="CpsSlider_ValueChanged"/>
                                <TextBox Grid.Column="1" x:Name="CpsInputBox" Text="10"
                                         Background="{StaticResource InputBg}" Foreground="#F0F0F5"
                                         BorderBrush="#2D2D4A" BorderThickness="1"
                                         Padding="8,4" Width="64" Height="34" FontSize="13"
                                         VerticalContentAlignment="Center" TextAlignment="Center"
                                         CaretBrush="#7C3AED" Margin="12,0,0,0"
                                         TextChanged="CpsInputBox_TextChanged"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="CLICK DUTY CYCLE" Style="{StaticResource SectionLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="DutySlider" Style="{StaticResource SliderCustom}"
                                        Value="50" Foreground="#EC4899"
                                        ValueChanged="DutySlider_ValueChanged"/>
                                <TextBox Grid.Column="1" x:Name="DutyInputBox" Text="50"
                                         Background="{StaticResource InputBg}" Foreground="#F0F0F5"
                                         BorderBrush="#2D2D4A" BorderThickness="1"
                                         Padding="8,4" Width="64" Height="34" FontSize="13"
                                         VerticalContentAlignment="Center" TextAlignment="Center"
                                         CaretBrush="#EC4899" Margin="12,0,0,0"
                                         TextChanged="DutyInputBox_TextChanged"
                                         PreviewTextInput="NumberOnly_PreviewTextInput"/>
                            </Grid>
                            <TextBlock Text="How long the button is held per click as % of the interval. 50% = half press, 100% = full hold." 
                                       Foreground="#6B7280" FontSize="10" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="PRESETS" Style="{StaticResource SectionLabel}"/>
                            <TextBlock Text="GLOBAL" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ItemsControl x:Name="PresetsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Background="#1A1A3A" BorderBrush="#7C3AED"
                                                BorderThickness="1" Margin="0,0,8,8" Cursor="Hand"
                                                MouseLeftButtonUp="PresetTile_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect" Value="{x:Null}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2D2D4A"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.3" Color="#7C3AED"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#7C3AED"/>
                                                            <Setter Property="BorderBrush" Value="#A855F7"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.4" Color="#7C3AED"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}" Foreground="#F0F0F5"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Margin="12,8" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="YOUR PRESETS" Foreground="#6B7280" FontSize="10" FontWeight="Bold" Margin="0,8,0,6"/>
                            <ItemsControl x:Name="UserPresetsList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Background="#1A1A3A" BorderBrush="#2D2D4A"
                                                BorderThickness="1" Margin="0,0,8,8" Cursor="Hand"
                                                MouseLeftButtonUp="PresetTile_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Effect" Value="{x:Null}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="#7C3AED"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="#7C3AED"/>
                                                            <Setter Property="BorderBrush" Value="#A855F7"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.4" Color="#7C3AED"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Margin="8,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Foreground="#F0F0F5"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Margin="4,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="✕" Foreground="#EF4444"
                                                           FontSize="11" Cursor="Hand"
                                                           MouseLeftButtonUp="DeletePreset_Click"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Border CornerRadius="8" Background="{StaticResource InputBg}" BorderBrush="#2D2D4A"
                                    BorderThickness="1" Padding="8,5" Margin="0,4,0,0"
                                    Width="340" HorizontalAlignment="Left">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Create:" Foreground="#9CA3AF" FontSize="9"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="NewPresetName" Grid.Column="1" Margin="4,0"
                                             Background="#12122A" Foreground="#F0F0F5"
                                             BorderBrush="#2D2D4A" BorderThickness="1"
                                             Padding="4,0" Height="22" FontSize="10"
                                             VerticalContentAlignment="Center"
                                             CaretBrush="#7C3AED"/>
                                    <Button Grid.Column="2" Content="Save" Width="44" Height="22"
                                            Background="#7C3AED" Foreground="#FFFFFF"
                                            BorderThickness="0" FontSize="9" FontWeight="Bold"
                                            Cursor="Hand" Click="SavePreset_Click"
                                            ToolTip="Save current CPS &amp; CDC as a preset"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="Set CPS &amp; CDC above, type a name, click Save."
                                       Foreground="#6B7280" FontSize="8" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="MOUSE BUTTON" Style="{StaticResource SectionLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <RadioButton x:Name="LeftRadio" Content="Left" Style="{StaticResource RadioOpt}" 
                                                 GroupName="MouseBtn" IsChecked="True" Checked="MouseBtn_Checked"/>
                                    <RadioButton x:Name="MiddleRadio" Content="Middle" Style="{StaticResource RadioOpt}" 
                                                 GroupName="MouseBtn" Checked="MouseBtn_Checked"/>
                                    <RadioButton x:Name="RightRadio" Content="Right" Style="{StaticResource RadioOpt}" 
                                                 GroupName="MouseBtn" Checked="MouseBtn_Checked"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ACTIVATION" Style="{StaticResource SectionLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <RadioButton x:Name="HoldRadio" Content="Hold" Style="{StaticResource RadioOpt}" 
                                                 GroupName="Act" Checked="Activation_Checked"/>
                                    <RadioButton x:Name="ToggleRadio" Content="Toggle" Style="{StaticResource RadioOpt}" 
                                                 GroupName="Act" IsChecked="True" Checked="Activation_Checked"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="HOTKEYS" Style="{StaticResource SectionLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Toggle:" Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center"/>
                                <Button x:Name="StartKeyBtn" Content="F6" Style="{StaticResource KeybindButton}" 
                                        Margin="8,0,0,0" Width="80" Click="StartKeyBtn_Click"/>
                            </StackPanel>
                            <TextBlock x:Name="KeybindHint" Text="" Foreground="#EC4899" FontSize="11" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border CornerRadius="20" Padding="14,6" Background="#1F2937">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#EF4444" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusLabel" Text="STOPPED" Foreground="#EF4444" 
                                           FontSize="11" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button x:Name="ResetStatsBtn" Content="Reset Stats" 
                                    Background="#1F2937" Foreground="#9CA3AF"
                                    Padding="14,6" Cursor="Hand" FontSize="11" Margin="0,0,8,0"
                                    BorderBrush="#2D2D4A" BorderThickness="1"
                                    Click="ResetStatsBtn_Click"/>
                            <Button Content="About" Background="Transparent" Foreground="#6B7280"
                                    BorderThickness="0" Padding="14,6" Cursor="Hand" FontSize="11"
                                    Click="AboutBtn_Click"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Width="12" Height="12" Margin="0,0,2,2" IsHitTestVisible="False">
                <TextBlock Text="◢" Foreground="#2D2D4A" FontSize="10" />
            </Border>
        </Grid>
    </Border>
</Window>